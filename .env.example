# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_SECRET=
AUTH_URL=
NEXTAUTH_URL=

# Optional OAuth provider. Leave unset to run the foundation without GitHub sign-in.
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
DATABASE_URL=postgresql://codemri:codemri@localhost:5432/codemri
REDIS_URL=redis://localhost:6379
REPOSITORY_WORKDIR=/tmp/codemri
MAX_REPOSITORY_FILES=10000
MAX_REPOSITORY_FILE_BYTES=1000000

# Integrations
GITHUB_TOKEN=
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
AI_CONTEXT_MAX_CHARS=120000
